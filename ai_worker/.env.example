# ---- LiveKit (HYBRID: cloud now, self-hosted later — only these change) ----
# Cloud:   wss://<your-project>.livekit.cloud
# Self:    wss://livekit.your-office-server:7880
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxx

# ---- DialFlow backend ----
DIALFLOW_BACKEND_URL=http://localhost:8000
AI_WORKER_TOKEN=set-a-long-random-shared-secret   # must match Django settings

# ---- Providers ----
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxx

# ---- Dispatch / transfer ----
AI_AGENT_DISPATCH_NAME=dialflow-ai
AI_TRANSFER_SIP_TEMPLATE=sip:queue-{queue_id}@your-fs-host:5060
